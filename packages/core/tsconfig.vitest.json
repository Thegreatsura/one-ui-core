{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "typeRoots": ["./types", "./node_modules/@types", "./node_modules"],
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "next-env.d.ts",
    "scss.d.ts",
    "vitest.config.ts",
    "src/test/**/*.ts",
    "src/test/**/*.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx"
  ],
  "exclude": ["node_modules", "dist"]
}
